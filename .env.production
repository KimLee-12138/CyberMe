# ── Application ──
APP_ENV=production
APP_BASE_URL=https://zhiyuekang.top
SECRET_KEY=change-this-to-a-strong-random-string-at-least-32-chars

# ── Database ──
DATABASE_URL=postgresql+asyncpg://cyberme:change-this-password@postgres:5432/cyberme

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── AI Providers ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
